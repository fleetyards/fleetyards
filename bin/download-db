#!/usr/bin/env bash

set -eu

# Load .env.local if present (worktree config)
if [ -f .env.local ]; then
  set -a
  # shellcheck disable=SC1091
  source .env.local
  set +a
fi

S3_BUCKET="fltyrd-live-backups"
S3_PREFIX="db"
S3_ENDPOINT="fsn1.your-objectstorage.com"
S3_ACCESS_KEY=$(op read "op://Fleetyards/HETZNER_S3/access_key_id")
S3_SECRET_KEY=$(op read "op://Fleetyards/HETZNER_S3/secret_access_key")
DUMP_DIR="./dumps"
DUMP_FILE="$DUMP_DIR/latest.dump"
DB_PORT="${DB_PORT:-8271}"
DB_NAME="${DB_NAME:-fleetyards_dev${WORKTREE_SUFFIX:-}}"
DB_USER="${DB_USER:-root}"

S3CMD="s3cmd --host=$S3_ENDPOINT --host-bucket=%(bucket)s.$S3_ENDPOINT --access_key=$S3_ACCESS_KEY --secret_key=$S3_SECRET_KEY"

mkdir -p "$DUMP_DIR"

echo "Fetching latest backup from s3://$S3_BUCKET/$S3_PREFIX/..."
LATEST=$($S3CMD ls "s3://$S3_BUCKET/$S3_PREFIX/" | sort | tail -1 | awk '{print $4}')

if [ -z "$LATEST" ]; then
  echo "ERROR: No backups found in s3://$S3_BUCKET/$S3_PREFIX/"
  exit 1
fi

REMOTE_MD5=$($S3CMD info "$LATEST" | grep 'MD5 sum' | awk '{print $3}')

if [ -f "$DUMP_FILE" ] && [ -n "$REMOTE_MD5" ]; then
  LOCAL_MD5=$(md5 -q "$DUMP_FILE" 2>/dev/null || md5sum "$DUMP_FILE" | awk '{print $1}')
  if [ "$LOCAL_MD5" = "$REMOTE_MD5" ]; then
    echo "Local dump is already up to date, skipping download."
  else
    echo "Downloading $LATEST..."
    $S3CMD get --force "$LATEST" "$DUMP_FILE"
  fi
else
  echo "Downloading $LATEST..."
  $S3CMD get --force "$LATEST" "$DUMP_FILE"
fi

echo "Dropping and recreating $DB_NAME..."
PGPASSWORD=password dropdb --if-exists -h localhost -U "$DB_USER" -p "$DB_PORT" "$DB_NAME"
PGPASSWORD=password createdb -h localhost -U "$DB_USER" -p "$DB_PORT" "$DB_NAME"

echo "Restoring to $DB_NAME on localhost:$DB_PORT..."
PG_RESTORE="pg_restore"
if [ -x "/opt/homebrew/opt/postgresql@16/bin/pg_restore" ]; then
  PG_RESTORE="/opt/homebrew/opt/postgresql@16/bin/pg_restore"
fi

PGPASSWORD=password $PG_RESTORE --verbose --no-acl --no-owner \
  -h localhost -U "$DB_USER" -p "$DB_PORT" -d "$DB_NAME" "$DUMP_FILE" || true

echo "Switching Active Storage blobs to local service..."
PGPASSWORD=password psql -h localhost -U "$DB_USER" -p "$DB_PORT" -d "$DB_NAME" \
  -c "UPDATE active_storage_blobs SET service_name = 'local' WHERE service_name = 'cloud';"

echo "Running migrations..."
DB_PORT="$DB_PORT" bin/rails db:migrate

echo "Updating test accounts..."

ADMIN_USERNAME=$(op read "op://Fleetyards/Test Admin/username")
ADMIN_PASSWORD=$(op read "op://Fleetyards/Test Admin/password")

FRONTEND_USERNAME=$(op read "op://Fleetyards/Test Frontend/username")
FRONTEND_PASSWORD=$(op read "op://Fleetyards/Test Frontend/password")

DB_PORT="$DB_PORT" bin/rails runner "
ActionMailer::Base.perform_deliveries = false

admin = AdminUser.find_by!(username: '$ADMIN_USERNAME')
admin.password = '$ADMIN_PASSWORD'
admin.password_confirmation = '$ADMIN_PASSWORD'
admin.otp_required_for_login = false
admin.save!
puts \"Admin account '#{admin.username}' updated.\"

user = User.find_by!(username: '$FRONTEND_USERNAME')
user.password = '$FRONTEND_PASSWORD'
user.password_confirmation = '$FRONTEND_PASSWORD'
user.save!
puts \"Frontend account '#{user.username}' updated.\"
"

echo "Done!"
