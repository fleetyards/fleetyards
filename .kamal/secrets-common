# All secrets are fetched from 1Password (vault: Fleetyards)
# Requires OP_SERVICE_ACCOUNT_TOKEN to be set in the environment

VAULT="Fleetyards"

# Shared secrets
KAMAL_REGISTRY_USERNAME=$(op read "op://$VAULT/KAMAL_REGISTRY/username")
S3_ACCESS_KEY_ID=$(op read "op://$VAULT/HETZNER_S3/access_key_id")
S3_SECRET_ACCESS_KEY=$(op read "op://$VAULT/HETZNER_S3/secret_access_key")

# Per-environment secrets (DESTINATION is set by Kamal via -d flag)
HCLOUD_TOKEN=$(op read "op://$VAULT/HCLOUD/$DESTINATION")
KAMAL_REGISTRY_PASSWORD=$(op read "op://$VAULT/KAMAL_REGISTRY/$DESTINATION")
RAILS_MASTER_KEY=$(op read "op://$VAULT/RAILS_MASTER_KEY/$DESTINATION")
POSTGRES_USER=$(op read "op://$VAULT/POSTGRES/${DESTINATION}_user")
POSTGRES_PASSWORD=$(op read "op://$VAULT/POSTGRES/${DESTINATION}_password")
