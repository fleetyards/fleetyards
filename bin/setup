#!/usr/bin/env ruby
require "fileutils"
require "zlib"
require "open3"

APP_ROOT = File.expand_path("..", __dir__)
require_relative "../lib/cli_helpers"
VERBOSE = ARGV.include?("--verbose")
FRESH = ARGV.include?("--fresh")
SKIP_ENV = ARGV.include?("--skip-env")
FORCE_ENV = ARGV.include?("--force-env")

def parse_flag(prefix)
  arg = ARGV.find { |a| a.start_with?("#{prefix}=") }
  arg&.split("=", 2)&.last
end

def parse_int_flag(prefix)
  parse_flag(prefix)&.to_i
end

PORT_OVERRIDE = parse_int_flag("--port")
VITE_PORT_OVERRIDE = parse_int_flag("--vite-port")
NAME_OVERRIDE = parse_flag("--name")
trap("INT") do
  print "\n"
  abort "Setup interrupted."
end

def format_duration(seconds) = CliHelpers.format_duration(seconds)
def run_step(label, cmd = nil, async: false, &block) = CliHelpers.run_step(label, cmd, verbose: VERBOSE, async:, &block)
def run_step_wait(*steps) = CliHelpers.run_step_wait(*steps, verbose: VERBOSE)

WORKTREE_MARKER = "# -- worktree-managed --"

def detect_worktree
  git_path = File.join(APP_ROOT, ".git")
  return nil unless File.file?(git_path)

  File.basename(APP_ROOT)
end

def main_worktree_root
  common_dir = `git -C "#{APP_ROOT}" rev-parse --path-format=absolute --git-common-dir 2>/dev/null`.strip
  return nil if common_dir.empty? || !File.directory?(common_dir)

  File.dirname(common_dir)
end

def worktree_port(name)
  8270 + (Zlib.crc32(name) % 500)
end

def worktree_vite_port(name)
  8273 + (Zlib.crc32(name) % 500)
end

def sanitize_worktree_name(name)
  name.gsub(/[^a-zA-Z0-9]/, "_")[0, 20]
end

def worktree_db_port(name)
  8271
end

def worktree_redis_port(name)
  8272
end

def worktree_db_suffix(name)
  "_wt_#{sanitize_worktree_name(name)}"
end

def worktree_sidekiq_redis_db(name)
  2 + (Zlib.crc32(name) % 500)
end

def write_env_local(port, db_port, redis_port, vite_port, db_suffix, sidekiq_redis_db)
  env_local = File.join(APP_ROOT, ".env.local")

  # Preserve user content above the marker
  user_content = ""
  if File.exist?(env_local)
    lines = File.readlines(env_local)
    marker_idx = lines.index { |l| l.strip == WORKTREE_MARKER }
    user_content = lines[0...marker_idx].join if marker_idx
    user_content = lines.join unless marker_idx
  end

  managed = <<~ENV
    #{WORKTREE_MARKER}
    PORT=#{port}
    DB_PORT=#{db_port}
    REDIS_URL=redis://localhost:#{redis_port}
    VITE_RUBY_PORT=#{vite_port}
    WORKTREE_SUFFIX=#{db_suffix}
    SIDEKIQ_REDIS_DB=#{sidekiq_redis_db}
  ENV

  File.write(env_local, user_content + managed)
end

if ARGV.include?("--help") || ARGV.include?("-h")
  puts <<~HELP
    Usage: bin/setup [OPTIONS]

    Set up or update the development environment. Idempotent.

    Options:
      --fresh         Wipe application state (Docker volumes) before setup
                      WARNING: affects all worktrees (shared Docker services)
      --skip-env      Skip symlinking .env from main worktree
      --force-env     Overwrite existing .env with symlink from main worktree
      --name=NAME     Override the worktree name used for DB suffix, ports, etc.
      --port=N        Override the Rails port (default: derived from name)
      --vite-port=N   Override the Vite dev server port (default: derived from name)
      --dev           Start the development server after setup
      --dev-<flag>    Forward --<flag> to bin/dev (e.g. --dev-docker, --dev-open)
      --verbose       Show full command output (default: concise status lines)
      --help          Show this help message
  HELP
  exit
end

FileUtils.chdir APP_ROOT do
  total_start = Process.clock_gettime(Process::CLOCK_MONOTONIC)

  wt_name = detect_worktree
  port = 8270
  db_port = 8271
  vite_port = 8274

  if wt_name
    effective_name = NAME_OVERRIDE || wt_name
    port = PORT_OVERRIDE || worktree_port(effective_name)
    db_port = worktree_db_port(effective_name)
    redis_port = worktree_redis_port(effective_name)
    vite_port = VITE_PORT_OVERRIDE || worktree_vite_port(effective_name)
    db_suffix = worktree_db_suffix(effective_name)
    sidekiq_db = worktree_sidekiq_redis_db(effective_name)

    if VERBOSE
      puts "== Worktree detected: #{wt_name}#{" (as #{effective_name})" if NAME_OVERRIDE} =="
      puts "   Rails port:  #{port}#{" (override)" if PORT_OVERRIDE}"
      puts "   Vite port:   #{vite_port}#{" (override)" if VITE_PORT_OVERRIDE}"
      puts "   DB port:     #{db_port}"
      puts "   Redis port:  #{redis_port}"
      puts "   DB suffix:   #{db_suffix}"
      puts "   Sidekiq DB:  #{sidekiq_db}"
    else
      puts "  Worktree: #{effective_name} (port #{port})"
    end

    write_env_local(port, db_port, redis_port, vite_port, db_suffix, sidekiq_db)
    puts "   Wrote .env.local" if VERBOSE

    env_file = File.join(APP_ROOT, ".env")
    if SKIP_ENV
      # skipped via flag, no output
    elsif !FORCE_ENV && (File.exist?(env_file) || File.symlink?(env_file))
      if VERBOSE
        puts "   .env already exists, skipping (use --force-env to overwrite)"
      else
        puts "  .env already exists, skipping (use --force-env to overwrite)"
      end
    else
      source_root = main_worktree_root
      if source_root
        source_env = File.join(source_root, ".env")
        if File.exist?(source_env)
          FileUtils.rm_f(env_file)
          FileUtils.ln_s(source_env, env_file)
          if VERBOSE
            puts "   Symlinked .env from #{source_root}"
          else
            puts "  Symlinked .env from main worktree"
          end
        end
      end
    end

    # Symlink credential keys from main worktree
    source_root = main_worktree_root
    if source_root
      %w[config/master.key config/credentials/production.key config/credentials/staging.key].each do |key_path|
        source_key = File.join(source_root, key_path)
        target_key = File.join(APP_ROOT, key_path)
        next unless File.exist?(source_key)
        next if File.exist?(target_key) || File.symlink?(target_key)

        FileUtils.mkdir_p(File.dirname(target_key))
        FileUtils.ln_s(source_key, target_key)
        puts VERBOSE ? "   Symlinked #{key_path} from main worktree" : "  Symlinked #{key_path}"
      end
    end
  end

  unless system("command -v pnpm > /dev/null 2>&1")
    abort "pnpm is not installed. Install it via: npm install -g pnpm"
  end

  # Ensure log/ and tmp/ directories exist (worktrees may not have them)
  FileUtils.mkdir_p(File.join(APP_ROOT, "log"))
  FileUtils.mkdir_p(File.join(APP_ROOT, "tmp"))

  if FRESH
    run_step "Wiping application state", "docker compose down -v"
  end

  # Group A: Install dependencies and start Docker (all independent)
  ruby_deps = run_step "Installing Ruby dependencies", "bundle check || bundle install", async: true
  node_deps = run_step "Installing Node dependencies", "pnpm install", async: true
  docker = run_step "Starting Docker services", "docker compose up -d --wait --wait-timeout 30", async: true
  run_step_wait(ruby_deps, node_deps, docker)

  # Group B: Prepare databases and build Vite test assets (need deps + Docker)
  dev_db = run_step "Preparing database (dev)", "DB_PORT=#{db_port} bin/rails db:prepare", async: true
  test_db = run_step "Preparing database (test)", "DB_PORT=#{db_port} RAILS_ENV=test bin/rails db:prepare", async: true
  vite_build = run_step "Building email assets (test)", "bin/build-email-assets", async: true
  run_step_wait(dev_db, test_db, vite_build)

  # Group C: Clean logs/tmp (need databases)
  clean = run_step "Cleaning logs and temp files", "bin/rails log:clear tmp:clear", async: true
  run_step_wait(clean)

  total_elapsed = Process.clock_gettime(Process::CLOCK_MONOTONIC) - total_start
  puts "\n== Setup complete in #{format_duration(total_elapsed)} =="

  start_server = ARGV.include?("--dev") || ARGV.any? { |arg| arg.start_with?("--dev-") }

  if start_server
    pids = `lsof -ti :#{port} -sTCP:LISTEN 2>/dev/null`.split.join(", ")
    unless pids.empty?
      abort "Port #{port} is already in use by PID #{pids}."
    end

    if VERBOSE
      puts "\n== Starting development server =="
    else
      puts "\n  Starting development server..."
    end
    $stdout.flush
    dev_args = ARGV.filter_map { |arg| arg.delete_prefix("--dev-") if arg.start_with?("--dev-") }
    exec("bin/dev", *dev_args.map { |a| "--#{a}" })
  end
end
