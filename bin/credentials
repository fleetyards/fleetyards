#!/usr/bin/env bash
set -euo pipefail

VAULT="Fleetyards"

usage() {
  echo "Usage: bin/credentials <environment>"
  echo ""
  echo "Edit Rails credentials using keys from 1Password."
  echo ""
  echo "Environments:"
  echo "  production   Edit config/credentials/production.yml.enc"
  echo "  staging      Edit config/credentials/staging.yml.enc"
  exit 1
}

if [ $# -lt 1 ]; then
  usage
fi

ENV="$1"

case "$ENV" in
  production)
    OP_ITEM="RAILS_MASTER_KEY_LIVE"
    RAILS_ENV_FLAG="--environment production"
    ;;
  staging)
    OP_ITEM="RAILS_MASTER_KEY_STAGE"
    RAILS_ENV_FLAG="--environment staging"
    ;;
  *)
    echo "Error: unknown environment '$ENV'"
    echo ""
    usage
    ;;
esac

if ! command -v op &> /dev/null; then
  echo "Error: 1Password CLI (op) is not installed."
  echo "Install it from: https://developer.1password.com/docs/cli/get-started/"
  exit 1
fi

echo "Fetching key for $ENV from 1Password..."
RAILS_MASTER_KEY=$(op read "op://$VAULT/$OP_ITEM/credential")
export RAILS_MASTER_KEY
export EDITOR="code --wait"

exec bin/rails credentials:edit $RAILS_ENV_FLAG
