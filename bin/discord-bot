#!/usr/bin/env bash
# Discord Gateway listener entry point.
#
# Locally: pulls DISCORD_BOT_TOKEN (and any other op:// references in
# .env.tpl / .env / .env.local) via the 1Password CLI, then runs the
# bot. Mirrors the bin/dev → bin/op pattern so contributors don't need
# to hand-edit .env.local with a token.
#
# In production / Kamal: the role's env.secret already injected
# DISCORD_BOT_TOKEN, and the container has no `op` CLI installed, so the
# wrapper skips bin/op and runs the script directly.
set -euo pipefail

cd "$(dirname "$0")/.."

if [ -z "${DISCORD_BOT_TOKEN:-}" ] && command -v op >/dev/null 2>&1; then
  exec bin/op ruby bin/discord-bot.rb "$@"
else
  exec ruby bin/discord-bot.rb "$@"
fi
